page {
  background: #f3f4f6;
  color: #111827;
  font-size: 28rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx;
}

.btn {
  background: #2563eb;
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  text-align: center;
}

.input {
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 16rpx;
  background: #fff;
}
