<view class="card">
  <view style="font-size:36rpx;font-weight:600;margin-bottom:24rpx;">家教平台登录</view>
  <input class="input" placeholder="账号" value="{{form.account}}" data-key="account" bindinput="onInput" />
  <input class="input" password placeholder="密码" value="{{form.password}}" data-key="password" bindinput="onInput" />
  <picker mode="selector" range="{{userTypeOptions}}" range-key="label" bindchange="onTypeChange">
    <view class="input">身份：{{userTypeOptions[form.userType].label}}</view>
  </picker>
  <view class="btn" bindtap="submit">登录</view>
  <view style="margin-top:16rpx;color:#6b7280;" bindtap="goRegister">没有账号？先注册</view>
</view>
