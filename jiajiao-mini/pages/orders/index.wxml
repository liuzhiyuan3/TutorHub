<view class="card" wx:for="{{list}}" wx:key="id">
  <view style="font-weight:600;">订单号：{{item.orderNumber}}</view>
  <view style="color:#6b7280;margin-top:8rpx;">金额：{{item.orderAmount}}</view>
  <view style="margin:8rpx 0;">状态：{{statusMap[item.orderStatus] || '未知'}}</view>
  <view style="display:flex;gap:10rpx;">
    <view class="btn" bindtap="updateStatus" data-id="{{item.id}}" data-status="1">进行中</view>
    <view class="btn" style="background:#16a34a;" bindtap="updateStatus" data-id="{{item.id}}" data-status="2">完成</view>
    <view class="btn" style="background:#6b7280;" bindtap="updateStatus" data-id="{{item.id}}" data-status="3">取消</view>
  </view>
</view>
