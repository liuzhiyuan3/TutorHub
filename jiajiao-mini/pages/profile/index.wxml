<view class="card">
  <view style="font-size:32rpx;font-weight:600;">我的信息</view>
  <view style="margin-top:12rpx;">姓名：{{user.userName || '-'}}</view>
  <view>账号：{{user.userAccount || '-'}}</view>
  <view>手机号：{{user.userPhone || '-'}}</view>
  <view>身份：{{user.userType === 0 ? '家长' : '教员'}}</view>
</view>

<view class="card" wx:if="{{user.userType === 1}}">
  <view style="font-size:30rpx;font-weight:600;">教员资料</view>
  <input class="input" placeholder="教员身份" value="{{teacher.teacherIdentity}}" data-key="teacherIdentity" bindinput="onTeacherInput" />
  <input class="input" placeholder="学校" value="{{teacher.teacherSchool}}" data-key="teacherSchool" bindinput="onTeacherInput" />
  <input class="input" placeholder="专业" value="{{teacher.teacherMajor}}" data-key="teacherMajor" bindinput="onTeacherInput" />
  <input class="input" placeholder="教龄" type="number" value="{{teacher.teacherTeachingYears}}" data-key="teacherTeachingYears" bindinput="onTeacherInput" />
  <textarea class="input" placeholder="教学经验" value="{{teacher.teacherExperience}}" data-key="teacherExperience" bindinput="onTeacherInput" />
  <view class="btn" bindtap="saveTeacher">保存教员资料</view>
</view>

<view class="card">
  <view class="btn" style="background:#6b7280;" bindtap="logout">退出登录</view>
</view>
