<view class="card">
  <input class="input" placeholder="需求标题" value="{{form.requirementTitle}}" data-key="requirementTitle" bindinput="onInput" />
  <input class="input" placeholder="需求描述" value="{{form.requirementDescription}}" data-key="requirementDescription" bindinput="onInput" />
  <picker mode="selector" range="{{subjects}}" range-key="subjectName" bindchange="onSubjectChange">
    <view class="input">学科：{{subjects[subjectIndex] ? subjects[subjectIndex].subjectName : '请选择'}}</view>
  </picker>
  <picker mode="selector" range="{{regions}}" range-key="regionName" bindchange="onRegionChange">
    <view class="input">区域：{{regions[regionIndex] ? regions[regionIndex].regionName : '请选择'}}</view>
  </picker>
  <input class="input" placeholder="年级，例如小学四年级" value="{{form.requirementGrade}}" data-key="requirementGrade" bindinput="onInput" />
  <input class="input" placeholder="授课地址" value="{{form.requirementAddress}}" data-key="requirementAddress" bindinput="onInput" />
  <input class="input" placeholder="薪资（元/小时）" type="number" value="{{form.requirementSalary}}" data-key="requirementSalary" bindinput="onInput" />
  <view class="btn" bindtap="submit">提交需求</view>
</view>
