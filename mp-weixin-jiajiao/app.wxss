@import 'miniprogram_npm/@vant/weapp/dist/common/index.wxss';
@import 'static/iconfont/iconfont.wxss';

page {
  --bg-page: #edf4ff;
  --bg-card: #ffffff;
  --bg-soft: #f5f9ff;
  --bg-soft-strong: #eef5ff;
  --text-main: #1a2f4f;
  --text-sub: #60799a;
  --text-light: #8ea3bf;
  --primary: #2f81f7;
  --primary-press: #2468d4;
  --success: #16a34a;
  --warning: #f59e0b;
  --danger: #dc2626;
  --line: #d6e5fc;
  --line-soft: #e7f0ff;
  --radius: 20rpx;
  --radius-sm: 14rpx;
  --space-xs: 8rpx;
  --space-sm: 14rpx;
  --space-md: 20rpx;
  --space-lg: 26rpx;
  --van-primary-color: #2f81f7;
  --van-success-color: #16a34a;
  --van-button-border-radius: 14rpx;
  --van-cell-background: #ffffff;
  --van-field-input-text-color: #1a2f4f;
  --van-field-label-color: #60799a;
  --van-cell-vertical-padding: 22rpx;
  --van-popup-background-color: #ffffff;
  background: var(--bg-page);
  color: var(--text-main);
  font-size: 28rpx;
  line-height: 1.55;
}

.page-wrap {
  padding: 22rpx;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 24rpx 22rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid var(--line-soft);
  box-shadow: 0 10rpx 24rpx rgba(43, 78, 132, 0.06);
}

.section-card {
  background: var(--bg-card);
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius);
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
}

.section-sub {
  font-size: 24rpx;
  color: var(--text-sub);
}

.section-desc {
  color: var(--text-sub);
  font-size: 24rpx;
  margin-top: 8rpx;
}

.btn {
  background: linear-gradient(180deg, #3e8cff, #2f7cf6);
  color: #fff;
  border-radius: var(--radius-sm);
  padding: 10rpx 14rpx;
  font-size: 24rpx;
  line-height: 1.3;
  text-align: center;
  font-weight: 600;
  box-shadow: 0 8rpx 18rpx rgba(47, 124, 246, 0.24);
}

.btn::after {
  border: 0;
}

.btn.secondary {
  background: linear-gradient(180deg, #7f90aa, #61728e);
}

.btn.wechat {
  background: linear-gradient(180deg, #35cc6d, #27b257);
  box-shadow: 0 8rpx 16rpx rgba(39, 178, 87, 0.2);
}

.btn.success {
  background: linear-gradient(180deg, #2cbc63, #16a34a);
}

.btn.ghost {
  background: #edf4ff;
  color: var(--primary);
  border: 1rpx solid #c9dcff;
  box-shadow: none;
}

.btn.danger {
  background: linear-gradient(180deg, #f55757, #dc2626);
}

.btn.disabled {
  background: #c5d0e1;
  color: #f8fafc;
  box-shadow: none;
}

.input {
  border: 1rpx solid var(--line);
  border-radius: var(--radius-sm);
  padding: 16rpx 18rpx;
  margin-bottom: 14rpx;
  background: #fff;
  color: var(--text-main);
}

.picker-field {
  border: 1rpx solid var(--line);
  border-radius: var(--radius-sm);
  padding: 16rpx 18rpx;
  margin-bottom: 14rpx;
  background: #fff;
  color: var(--text-main);
}

.tag {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag.pending {
  background: #fff7e2;
  color: #9a630b;
}

.tag.success {
  background: #eaf9ef;
  color: #13723a;
}

.tag.error {
  background: #ffebeb;
  color: #bb2626;
}

.tag.info {
  background: #e8f1ff;
  color: #2f67c8;
}

.muted {
  color: var(--text-sub);
}

.empty-box {
  padding: 32rpx 22rpx;
  text-align: center;
  color: var(--text-sub);
  border: 1rpx dashed #cfdcf2;
  border-radius: var(--radius-sm);
  background: var(--bg-soft);
}

.error-box {
  margin-bottom: 16rpx;
  padding: 16rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid #fecaca;
  background: #fff1f1;
  color: #b91c1c;
}

.skeleton {
  height: 28rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #ecf2fb 25%, #f7faff 37%, #ecf2fb 63%);
  background-size: 400% 100%;
  animation: shimmer 1.1s ease-in-out infinite;
}

.hero-banner {
  border-radius: 22rpx;
  padding: 30rpx 24rpx;
  color: #fff;
  background: linear-gradient(145deg, #0ecf7a, #0abf71 58%, #0aa765);
  box-shadow: 0 14rpx 32rpx rgba(10, 167, 101, 0.28);
}

.hero-title {
  font-size: 62rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.hero-subtitle {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.hero-tip {
  margin-top: 12rpx;
  display: inline-block;
  background: rgba(255, 255, 255, 0.85);
  color: #d9831f;
  border-radius: 10rpx;
  padding: 8rpx 12rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.chip-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d7e5fc;
  background: #f6faff;
  color: #2d5a96;
  font-size: 22rpx;
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--space-sm);
}

.tab-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 136rpx);
}

.section-title-wrap {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.section-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--primary);
  background: #eaf2ff;
}

.inline-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
}

.mt-8r {
  margin-top: 8rpx;
}

.mt-10r {
  margin-top: 10rpx;
}

.mt-12r {
  margin-top: 12rpx;
}

.mt-16r {
  margin-top: 16rpx;
}

.mb-8r {
  margin-bottom: 8rpx;
}

.line {
  margin-top: 16rpx;
}

.line-short {
  width: 72%;
}

.line-mid {
  width: 60%;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.btn-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.retry-btn {
  margin-top: 10rpx;
}

@keyframes shimmer {
  0% {
    background-position: 100% 0;
  }
  100% {
    background-position: 0 0;
  }
}
