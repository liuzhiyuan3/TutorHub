.auth-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}

.auth-sheet {
  width: 100%;
  background: #fff;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  padding: 26rpx 26rpx 36rpx;
}

.auth-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a2f4f;
}

.auth-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6a7f9c;
}

.role-row {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
}

.role-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 999rpx;
  border: 1rpx solid #cddcf8;
  color: #4e6485;
  background: #f5f8ff;
}

.role-item.active {
  border-color: #2f7cf6;
  background: #e8f1ff;
  color: #2f67c8;
  font-weight: 700;
}

.auth-btn {
  margin-top: 20rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffd957, #f6c732);
  color: #3d3200;
  font-size: 30rpx;
  font-weight: 700;
  height: 86rpx;
  line-height: 86rpx;
}

.skip-btn {
  margin-top: 14rpx;
  text-align: center;
  color: #6b809f;
  font-size: 28rpx;
  padding: 10rpx 0 2rpx;
}

.protocol-tip {
  margin-top: 12rpx;
  text-align: center;
  color: #8fa0b9;
  font-size: 22rpx;
}
