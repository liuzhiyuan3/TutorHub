.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 32, 56, 0.36);
  z-index: 99;
  display: flex;
  align-items: flex-end;
}

.sheet-main {
  width: 100%;
  background: #fff;
  border-radius: 26rpx 26rpx 0 0;
  box-shadow: 0 -12rpx 36rpx rgba(37, 70, 120, 0.18);
  padding: 20rpx 20rpx 28rpx;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.sheet-title {
  font-size: 30rpx;
  color: #243f67;
  font-weight: 700;
}

.sheet-close {
  font-size: 24rpx;
  color: #6f86a8;
}
