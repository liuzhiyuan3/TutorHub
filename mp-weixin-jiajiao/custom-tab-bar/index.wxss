@import "../static/iconfont/iconfont.wxss";

.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 10rpx 16rpx calc(env(safe-area-inset-bottom) + 10rpx);
  background: transparent;
  z-index: 999;
}

.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid #d3e3ff;
  box-shadow: 0 10rpx 24rpx rgba(47, 103, 200, 0.14);
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  height: 84rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #6f839f;
}

.tab-item.active {
  background: linear-gradient(180deg, #eff6ff, #e5efff);
  border: 1rpx solid #cfe0ff;
  color: #2f67c8;
}

.tab-icon {
  font-size: 36rpx;
  line-height: 1;
}

.tab-text {
  font-size: 20rpx;
  line-height: 1;
  font-weight: 600;
}
