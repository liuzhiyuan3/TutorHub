.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.hero-banner-plus {
  position: relative;
  overflow: hidden;
}

.hero-banner-plus::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 86rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(10, 170, 105, 0.4));
  pointer-events: none;
}

.hero-banner-plus::after {
  content: '';
  position: absolute;
  right: -120rpx;
  top: -90rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hero-city {
  font-size: 32rpx;
  font-weight: 700;
}

.hero-role {
  font-size: 22rpx;
  opacity: 0.92;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
}

.quick-card {
  margin-top: -20rpx;
  position: relative;
  z-index: 2;
  border: 1rpx solid #dfeafc;
  box-shadow: 0 16rpx 30rpx rgba(38, 69, 118, 0.08);
}

.role-grid {
  margin-top: 14rpx;
}

.core-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.guest-tip {
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  border: 1rpx dashed #bcd3f8;
  background: #f4f9ff;
  color: #5f7798;
  font-size: 23rpx;
}

.guest-tip .btn {
  margin-top: 10rpx;
}

.grid-item {
  background: linear-gradient(180deg, #f8fbff, #eef5ff);
  border: 1rpx solid #d5e4fb;
  border-radius: 16rpx;
  padding: 20rpx;
}

.core-item {
  background: linear-gradient(180deg, #f7fbff, #edf5ff);
  border: 1rpx solid #d5e4fb;
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  text-align: center;
}

.grid-item-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  color: #2f67c8;
  background: #e8f1ff;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.section-title-sm {
  font-size: 30rpx;
}

.grid-title {
  font-size: 28rpx;
  color: #1f3f72;
  font-weight: 700;
}

.grid-sub {
  margin-top: 6rpx;
  color: #607491;
  font-size: 22rpx;
}

.service-entry-card {
  border: 1rpx solid #dce8fc;
  background: linear-gradient(180deg, #fbfdff, #f5f9ff);
}

.service-toggle-hint {
  color: #607491;
  font-size: 23rpx;
  margin-bottom: 12rpx;
}

.retry-btn {
  margin-top: 10rpx;
}

.line {
  margin-top: 16rpx;
}

.short {
  width: 72%;
}

.banner-list,
.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.banner-item {
  width: 100%;
  padding: 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid #dce8fc;
  background: #f7fbff;
}

.banner-img {
  width: 100%;
  height: 220rpx;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}

.banner-title {
  font-size: 26rpx;
  color: #1f3f72;
  font-weight: 600;
}

.banner-url {
  margin-top: 6rpx;
  color: #5f7694;
  font-size: 22rpx;
}

.tag-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f1f7ff;
  color: #2f67c8;
  font-size: 22rpx;
  border: 1rpx solid #d7e5fc;
}

.req-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #edf3ff;
}

.req-item:last-child {
  border-bottom: 0;
}

.req-title {
  color: #23426f;
  font-size: 26rpx;
  font-weight: 600;
}

.req-sub {
  margin-top: 6rpx;
  color: #647c9c;
  font-size: 22rpx;
}

.dispatch-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #edf3ff;
}

.dispatch-item:last-child {
  border-bottom: 0;
}

.dispatch-top {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.dispatch-region {
  color: #f08a1f;
  font-weight: 700;
  font-size: 34rpx;
  min-width: 90rpx;
}

.dispatch-main {
  flex: 1;
  color: #1f3f72;
  font-size: 28rpx;
  font-weight: 600;
}

.dispatch-no {
  color: #6b7f9c;
  font-size: 28rpx;
}

.dispatch-sub {
  margin-top: 8rpx;
  color: #6f839f;
  font-size: 24rpx;
  padding-left: 104rpx;
}

.ad-item {
  padding: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e1ebfd;
  background: #f9fbff;
  margin-bottom: 10rpx;
}

.ad-img {
  width: 100%;
  height: 180rpx;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}

.ad-title {
  color: #23426f;
  font-weight: 600;
}

.ad-url {
  margin-top: 4rpx;
  color: #657e9f;
  font-size: 22rpx;
}

.teacher-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #edf3ff;
}

.teacher-row:last-child {
  border-bottom: none;
}

.teacher-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d8e7fb;
  background: #eef5ff;
  overflow: hidden;
  flex: 0 0 auto;
  display: block;
}

.teacher-avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6280a6;
  font-size: 24rpx;
}

.teacher-main {
  flex: 1;
}

.teacher-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f3f72;
}

.teacher-meta {
  margin-top: 4rpx;
  color: #5f7694;
  font-size: 23rpx;
}
