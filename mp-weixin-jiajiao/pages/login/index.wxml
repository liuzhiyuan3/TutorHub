<view class="page-wrap login-page">
  <view class="login-bg-shape login-bg-shape-a"></view>
  <view class="login-bg-shape login-bg-shape-b"></view>

  <view class="login-shell">
    <view class="brand-block">
      <view class="brand-pill">
        <text class="i i-home inline-icon"></text>
        家教平台
      </view>
      <view class="welcome-title">欢迎登录</view>
      <view class="welcome-sub">优先推荐微信一键登录，也支持账号密码登录</view>
    </view>

    <view class="login-card">
      <view class="entry-switch">
        <view
          class="switch-item {{loginEntryMode === 'wechat' ? 'switch-item-active' : ''}}"
          bindtap="switchToWechatLogin"
        >
          微信登录
        </view>
        <view
          class="switch-item {{loginEntryMode === 'account' ? 'switch-item-active' : ''}}"
          bindtap="switchToAccountLogin"
        >
          账号登录
        </view>
      </view>

      <view wx:if="{{loginEntryMode === 'wechat'}}" class="entry-block">
        <view class="entry-head">
          <text class="i i-wechat entry-icon"></text>
          <view class="entry-title">微信授权登录</view>
        </view>
        <picker mode="selector" range="{{userTypeOptions}}" range-key="label" bindchange="onTypeChange">
          <view class="picker-field identity-picker">当前身份：{{currentUserTypeLabel}}</view>
        </picker>
        <van-button
          type="success"
          custom-class="primary-login-btn"
          loading="{{submitting}}"
          bind:click="openConfirmSheet"
        >
          {{primaryBtnText}}
        </van-button>
        <view class="entry-tip">点击按钮后将拉起微信授权流程</view>
        <view class="entry-link" bindtap="switchToAccountLogin">使用账号密码登录</view>
      </view>

      <view wx:else class="entry-block">
        <view class="entry-head">
          <text class="i i-profile entry-icon"></text>
          <view class="entry-title">账号密码登录</view>
        </view>
        <picker mode="selector" range="{{userTypeOptions}}" range-key="label" bindchange="onTypeChange">
          <view class="picker-field identity-picker">当前身份：{{currentUserTypeLabel}}</view>
        </picker>
        <van-field
          custom-class="assist-field"
          label="账号"
          placeholder="请输入账号"
          value="{{form.account}}"
          data-key="account"
          border="{{false}}"
          bind:input="onInput"
        />
        <van-field
          custom-class="assist-field"
          label="密码"
          type="password"
          placeholder="请输入密码"
          value="{{form.password}}"
          data-key="password"
          border="{{false}}"
          bind:input="onInput"
        />
        <van-button
          type="primary"
          loading="{{submitting}}"
          custom-class="assist-login-btn"
          bind:click="submit"
        >
          {{submitText}}
        </van-button>
        <view class="entry-link" bindtap="goRegister">没有账号？去注册</view>
        <view class="entry-link link-back" bindtap="switchToWechatLogin">返回微信一键登录</view>
      </view>

      <view class="error-strip" wx:if="{{authStage === 'failed' && errorText}}">
        <text class="i i-menu inline-icon"></text>
        {{errorText}}
      </view>
      <view class="agreement-tip">登录即表示你同意《用户协议》和《隐私政策》</view>
    </view>
  </view>

  <van-popup show="{{showConfirmSheet}}" position="bottom" round bind:close="closeConfirmSheet">
    <view class="confirm-sheet">
      <view class="confirm-title">
        <text class="i i-wechat inline-icon"></text>
        确认微信授权登录
      </view>
      <view class="confirm-desc">确认后将使用当前身份发起微信登录并同步基础信息</view>
      <view class="confirm-actions">
        <van-button plain type="primary" custom-class="confirm-btn" bind:click="closeConfirmSheet">取消</van-button>
        <van-button type="success" custom-class="confirm-btn" bind:click="confirmWechatLogin">确认登录</van-button>
      </view>
    </view>
  </van-popup>

  <profile-complete-sheet
    visible="{{showProfileCompleteSheet}}"
    role="{{profileRole}}"
    canSkip="{{profileCanSkip}}"
    missingFields="{{profileMissingFields}}"
    initNickName="{{profileInitNickName}}"
    initAvatarUrl="{{profileInitAvatarUrl}}"
    bind:success="onProfileCompleteSuccess"
    bind:skip="onProfileCompleteSkip"
    bind:close="onProfileCompleteClose"
  />
</view>
