.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #f3f8ff 0%, #ecf4ff 42%, #eef9f4 100%);
  padding: 34rpx 24rpx 44rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.login-bg-shape {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.login-bg-shape-a {
  width: 360rpx;
  height: 360rpx;
  right: -110rpx;
  top: -90rpx;
  background: radial-gradient(circle, rgba(53, 129, 239, 0.2) 0%, rgba(53, 129, 239, 0) 72%);
}

.login-bg-shape-b {
  width: 420rpx;
  height: 420rpx;
  left: -160rpx;
  bottom: -40rpx;
  background: radial-gradient(circle, rgba(29, 184, 106, 0.18) 0%, rgba(29, 184, 106, 0) 74%);
}

.login-shell {
  min-height: calc(100vh - 66rpx);
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  z-index: 2;
}

.brand-block {
  text-align: center;
  margin-bottom: 30rpx;
}

.brand-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid #cce0ff;
  background: rgba(255, 255, 255, 0.9);
  color: #1f5ea8;
  font-size: 24rpx;
  font-weight: 700;
}

.welcome-title {
  margin-top: 20rpx;
  font-size: 52rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #1f2d45;
}

.welcome-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #607894;
}

.welcome-safe-tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7a90aa;
}

.login-card {
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid #dbe8fb;
  border-radius: 28rpx;
  padding: 30rpx 26rpx 26rpx;
  box-shadow: 0 16rpx 42rpx rgba(40, 73, 124, 0.12);
}

.entry-switch {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  padding: 10rpx;
  border-radius: 16rpx;
  background: #f4f8ff;
  margin-bottom: 20rpx;
}

.switch-item {
  min-height: 76rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  color: #5f7898;
  background: transparent;
  border: 1rpx solid transparent;
  font-weight: 600;
}

.switch-item-active {
  background: #ffffff;
  color: #1f66c2;
  border-color: #cfe0fb;
}

.entry-block {
  border: 1rpx solid #deebfb;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #ffffff, #f9fcff);
  padding: 26rpx 22rpx 24rpx;
}

.entry-head {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.entry-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background: #ebf3ff;
  color: #2f67c8;
  font-size: 24rpx;
}

.entry-title {
  font-size: 29rpx;
  font-weight: 700;
  color: #243958;
}

.identity-tabs {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.identity-tab {
  min-height: 66rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d7e6fb;
  background: #ffffff;
  color: #5f7898;
  font-size: 25rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.identity-tab-active {
  color: #1f66c2;
  border-color: #2f7cf6;
  background: #edf4ff;
}

.identity-summary {
  margin-bottom: 16rpx;
  border: 1rpx solid #d7e6fb;
  border-radius: 14rpx;
  font-size: 25rpx;
  color: #3d5578;
  background: #ffffff;
  padding: 14rpx 16rpx;
}

.wechat-btn-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
}

.assist-btn-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
}

.primary-login-btn,
.assist-login-btn {
  width: 100%;
  max-width: 560rpx;
  margin: 12rpx auto 0 !important;
  height: 78rpx !important;
  border-radius: 14rpx !important;
  font-size: 27rpx !important;
  font-weight: 700 !important;
}

.assist-field {
  border: 1rpx solid #d8e6fb;
  border-radius: 14rpx;
  background: #ffffff;
  margin-bottom: 14rpx;
}

.entry-tip {
  margin-top: 14rpx;
  text-align: center;
  color: #6b84a1;
  font-size: 23rpx;
}

.entry-link {
  margin-top: 14rpx;
  text-align: center;
  color: #2a74d5;
  font-size: 25rpx;
  font-weight: 600;
}

.link-back {
  color: #4e7099;
  font-weight: 500;
}

.error-strip {
  margin-top: 14rpx;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid #fecaca;
  background: #fff3f3;
  color: #b42318;
  font-size: 23rpx;
}

.agreement-tip {
  margin-top: 18rpx;
  text-align: center;
  color: #7d93ae;
  font-size: 22rpx;
  line-height: 1.7;
}
