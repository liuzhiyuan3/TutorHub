<view class="page-wrap">
  <view class="card">
    <view class="section-title section-title-sm">订单支付</view>
    <view class="section-sub">仿真支付流程（开发联调用）</view>
    <view class="muted line">订单号：{{orderNumber || '-'}}</view>
    <view class="muted line">订单金额：{{orderAmount || 0}}</view>
    <view class="muted line">支付倒计时：{{remainText}}</view>
  </view>

  <view wx:if="{{loading}}" class="card">
    <view class="skeleton line-mid"></view>
    <view class="skeleton line"></view>
  </view>

  <view wx:else class="card">
    <view wx:if="{{timedOut}}" class="error-box">支付已超时，请重新发起或取消订单</view>
    <view wx:if="{{!timedOut}}" class="btn" bindtap="confirmPay">{{paying ? '支付中...' : '确认支付'}}</view>
    <view class="btn ghost mt-12r" bindtap="onRetryPay">重新发起支付</view>
    <view class="btn secondary mt-12r" bindtap="cancelPay">取消订单</view>
  </view>
  <auth-sheet
    visible="{{authSheetVisible}}"
    role="{{authSheetRole}}"
    bindclose="onAuthSheetClose"
    bindsuccess="onAuthSheetSuccess"
  />
</view>
