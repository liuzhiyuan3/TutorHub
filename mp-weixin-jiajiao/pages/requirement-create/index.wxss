.section-title-sm {
  font-size: 30rpx;
}
.publish-head {
  margin-bottom: 18rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #e6eef9;
}
.group-title {
  margin: 12rpx 0 10rpx;
  color: #445f86;
  font-weight: 600;
}

.van-field-lite {
  border: 1rpx solid #d6e2f3;
  border-radius: 12rpx;
  background: #fafcff;
  margin-bottom: 12rpx;
}

.textarea {
  min-height: 120rpx;
}

.retry-btn {
  margin-top: 10rpx;
}

.upload-wrap {
  margin: 10rpx 0 6rpx;
  padding: 14rpx;
  border: 1rpx dashed #d6e4fa;
  border-radius: 14rpx;
  background: #f9fcff;
}

.upload-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.upload-btn {
  min-width: 160rpx !important;
}

.img-grid {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.img-item {
  width: 180rpx;
}

.img-preview {
  width: 180rpx;
  height: 132rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d9e8fd;
}

.img-remove {
  margin-top: 6rpx;
  text-align: center;
  color: #d64a4a;
  font-size: 22rpx;
}

.salary-wrap {
  margin: 8rpx 0 10rpx;
  padding: 12rpx;
  border: 1rpx solid #e4ecf8;
  border-radius: 12rpx;
  background: #f9fbff;
}

.location-row {
  margin-bottom: 14rpx;
  padding: 10rpx 12rpx;
  border: 1rpx dashed #d7e4f8;
  border-radius: 12rpx;
  background: #f9fcff;
}

.location-btn {
  display: inline-block !important;
}

.location-tip {
  margin-top: 8rpx;
  color: #6380a6;
  font-size: 22rpx;
}

.location-status {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.location-status.ok {
  color: #2a8a4b;
}

.location-status.error {
  color: #c43d3d;
}
.field-note {
  margin-top: 8rpx;
  color: #7a8eaa;
  font-size: 22rpx;
}

.submit-btn {
  margin-top: 14rpx;
}

.sheet-body {
  padding: 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.sheet-title {
  font-size: 30rpx;
  color: #243f67;
  font-weight: 700;
}

.sheet-close {
  font-size: 24rpx;
  color: #6f86a8;
}

.sheet-btn {
  margin-top: 10rpx;
}

.ghost-gap {
  margin-top: 12rpx;
}

.sheet-tip {
  margin-top: 12rpx;
  padding: 10rpx 12rpx;
  border-radius: 10rpx;
  background: #f4f8ff;
}
