.retry-btn {
  margin-top: 10rpx;
}

.section-title-sm {
  font-size: 30rpx;
}

.detail-card {
  padding: 26rpx 24rpx;
}

.profile-head {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.profile-avatar-wrap {
  flex: 0 0 auto;
  width: 168rpx;
  height: 168rpx;
  border-radius: 14rpx;
  overflow: hidden;
  border: 1rpx solid #d8e7fb;
  background: #eef5ff;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.teacher-photo {
  width: 100%;
  height: 100%;
  border-radius: 0;
  border: 0;
  background: transparent;
  display: block;
}

.teacher-photo-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 0;
  border: 1rpx dashed #d0ddf4;
  background: #f6faff;
  color: #6e86a5;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.line-text {
  margin-top: 8rpx;
  color: #3f587e;
}

.desc-title {
  margin-top: 16rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  color: #2a4670;
  font-weight: 600;
}

.desc {
  color: #5d7392;
  background: #f7faff;
  border: 1rpx solid #e3edff;
  border-radius: 12rpx;
  padding: 12rpx 14rpx;
}

.ops {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.bottom-ops {
  position: sticky;
  bottom: 0;
  z-index: 3;
  background: rgba(237, 244, 255, 0.96);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  padding: 12rpx 0 4rpx;
}
.bottom-ops .btn {
  padding: 10rpx 12rpx;
  font-size: 23rpx;
}

.record-row {
  display: flex;
  justify-content: space-between;
  border-bottom: 1rpx solid #edf3ff;
  padding: 10rpx 0;
  color: #4b6486;
  font-size: 24rpx;
}

.record-row:last-child {
  border-bottom: none;
}

.record-grade {
  color: #1f3f72;
  font-weight: 600;
}

.reserve-panel {
  border: 1rpx solid #dce8fb;
}

.line {
  margin-top: 16rpx;
}

.short {
  width: 70%;
}
