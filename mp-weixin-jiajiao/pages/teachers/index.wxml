<view class="page-wrap">
  <view class="card filter-card">
    <view class="section-head">
      <view class="section-title-wrap"><text class="section-icon i i-search"></text><view class="section-title section-title-sm">找老师</view></view>
      <view class="section-sub">已展示 {{ list.length }} 位</view>
    </view>

    <view class="filter-bar">
      <view class="filter-group-title">常用筛选</view>
      <view class="filter-top">
        <view class="chip chip-main" bindtap="onTapCurrentDistrict"><text class="i i-location inline-icon"></text>{{currentDistrictText}}<text class="i i-menu chip-arrow-icon"></text></view>
        <view class="chip chip-toggle {{nearbyOnly ? 'chip-active' : ''}}" bindtap="toggleNearby"><text class="i i-location inline-icon"></text>附近{{nearbyKm}}km</view>
        <picker mode="selector" range="{{sortOptions}}" range-key="label" bindchange="onSortChange">
          <view class="chip chip-sort">{{sortOptions[sortIndex].label}}<text class="i i-menu chip-arrow-icon"></text></view>
        </picker>
      </view>

      <view class="region-cascade">
        <picker mode="selector" range="{{provinceOptions}}" range-key="name" bindchange="onProvinceChange">
          <view class="chip chip-cascade">{{selectedProvinceName || '全部省份'}}<text class="i i-menu chip-arrow-icon"></text></view>
        </picker>
        <picker mode="selector" range="{{cityOptions}}" range-key="name" bindchange="onCityChange">
          <view class="chip chip-cascade">{{selectedCityName || '全部城市'}}<text class="i i-menu chip-arrow-icon"></text></view>
        </picker>
      </view>

      <scroll-view class="district-scroll" scroll-x="true" show-scrollbar="false">
        <view wx:for="{{districtChips}}" wx:key="id" class="chip chip-district {{activeDistrictId === item.id ? 'chip-active' : ''}}" data-id="{{item.id}}" bindtap="chooseDistrict">{{item.name}}</view>
      </scroll-view>

      <view class="quick-actions">
        <view class="chip chip-action {{query.subjectId ? 'chip-active' : ''}}" bindtap="openSubjectPanel"><text class="i i-search inline-icon"></text>{{selectedSubjectName || '科目'}}<text class="i i-menu chip-arrow-icon"></text></view>
        <view class="chip chip-action {{advancedVisible ? 'chip-active' : ''}}" bindtap="toggleAdvanced"><text class="i i-menu inline-icon"></text>{{advancedVisible ? '收起' : '筛选'}}</view>
      </view>
    </view>

    <view class="advanced-panel" wx:if="{{advancedVisible}}">
      <view class="filter-group-title">高级筛选</view>
      <input class="input" placeholder="关键词（身份/学校/专业）" value="{{query.keyword}}" bindinput="onKeywordInput" />
      <input class="input" placeholder="学校关键词（可选）" value="{{query.schoolKeyword}}" bindinput="onSchoolKeywordInput" />
      <view class="filter-actions">
        <view class="btn secondary" bindtap="resetFilters">清空筛选</view>
        <view class="btn ghost" bindtap="loadFilters">刷新筛选</view>
        <view class="btn" bindtap="onSearch">应用筛选</view>
      </view>
    </view>

    <view wx:if="{{showSubjectPanel}}" class="subject-panel-mask" bindtap="closeSubjectPanel">
      <view class="subject-panel" catchtap="noop">
        <view class="subject-panel-head">
          <text class="subject-panel-title">学科筛选</text>
          <text class="subject-panel-reset" bindtap="resetSubjectFilter">重置</text>
        </view>
        <view class="subject-panel-sub">左侧选分类，右侧选子学科，立即筛选老师</view>
        <view class="subject-panel-body">
          <scroll-view class="category-col" scroll-y="true">
            <view wx:for="{{subjectCategoryTree}}" wx:key="id" data-index="{{index}}" bindtap="chooseCategory" class="category-item {{activeCategoryIndex === index ? 'active' : ''}}">{{item.categoryName}}</view>
          </scroll-view>
          <scroll-view class="subject-col" scroll-y="true">
            <view class="subject-chip {{query.subjectId === '' ? 'active' : ''}}" bindtap="resetSubjectFilter">全部学科</view>
            <view wx:for="{{currentCategorySubjects}}" wx:key="id" data-id="{{item.id}}" data-name="{{item.name}}" bindtap="chooseSubject" class="subject-chip {{query.subjectId === item.id ? 'active' : ''}}">{{item.name}}</view>
            <view wx:if="{{!currentCategorySubjects.length}}" class="subject-empty">当前分类暂无子学科</view>
          </scroll-view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{error}}" class="error-box">
    {{error}}
    <view class="btn ghost retry-btn" bindtap="load">重试</view>
  </view>

  <view wx:if="{{loading}}">
    <view class="card skeleton-card" wx:for="{{3}}" wx:key="*this">
      <view class="skeleton line-short"></view>
      <view class="skeleton line"></view>
      <view class="skeleton line short"></view>
    </view>
  </view>

  <view wx:elif="{{!list.length}}" class="card">
    <mp-empty text="暂无教员数据" iconType="i-search" />
  </view>

  <block wx:else>
    <view class="card teacher-card" wx:for="{{list}}" wx:key="teacherId" bindtap="goDetail" data-id="{{item.teacherId}}">
      <view class="teacher-card-inner">
        <image
          wx:if="{{item.teacherPhoto && !item.avatarError}}"
          class="teacher-avatar"
          src="{{item.teacherPhoto}}"
          mode="aspectFill"
          data-id="{{item.teacherId}}"
          binderror="onAvatarError"
        ></image>
        <view wx:else class="teacher-avatar placeholder">暂无</view>
        <view class="teacher-main">
          <view class="teacher-row1">
            <view class="teacher-name">{{item.userName || item.identityText}}</view>
            <view class="chip-mini">{{item.teacherTeachingYears || 0}}年</view>
            <view class="chip-mini chip-green" wx:if="{{item.auditStatus === 1}}">已认证</view>
          </view>
          <view class="teacher-row2">{{item.subjectText}}</view>
          <view class="teacher-row3">{{item.teacherSchool || '-' }} · {{item.teacherMajor || '-'}} · {{item.teacherEducation || '-'}}</view>
          <view class="teacher-row4">
            <view class="teacher-distance" wx:if="{{item.distanceText}}">{{item.distanceText}}</view>
            <view class="teacher-meta">成交{{item.historyDealCount || 0}}单</view>
            <view class="teacher-meta">成功{{item.teacherSuccessCount || 0}}次</view>
            <view class="teacher-meta">热度{{item.teacherViewCount || 0}}</view>
          </view>
          <view class="teacher-row5">区域：{{item.regionText}} · 身份：{{item.identityText || '-'}}</view>
        </view>
      </view>
      <view class="btn teacher-cta">查看详情</view>
    </view>
  </block>

  <view wx:if="{{list.length}}" class="card load-more-card">
    <mp-reach-bottom loading="{{loading}}" hasMore="{{hasMore}}" bind:loadmore="onLoadMore" />
  </view>
</view>
