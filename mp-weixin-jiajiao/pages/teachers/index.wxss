.section-title-sm {
  font-size: 28rpx;
}

.filter-card {
  margin-top: 6rpx;
  position: sticky;
  top: 0;
  z-index: 8;
  background: rgba(237, 244, 255, 0.96);
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
  padding: 12rpx;
}

.filter-bar {
  margin-top: 6rpx;
  padding-top: 6rpx;
  border-top: 1rpx solid #dbe7fb;
}

.filter-top {
  display: flex;
  align-items: stretch;
  gap: 6rpx;
  flex-wrap: wrap;
}

.filter-top picker {
  flex: 1 1 calc(33.33% - 7rpx);
  min-width: 0;
}

.filter-top .chip {
  flex: 1 1 calc(33.33% - 7rpx);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.district-scroll {
  margin-top: 6rpx;
  white-space: nowrap;
}

.region-cascade {
  margin-top: 6rpx;
  display: flex;
  gap: 6rpx;
}

.region-cascade picker {
  flex: 1 1 calc(50% - 3rpx);
  min-width: 0;
}

.chip-cascade {
  width: 100%;
  border-radius: 12rpx;
}

.quick-actions {
  margin-top: 6rpx;
  display: flex;
  gap: 6rpx;
  flex-wrap: wrap;
}

.chip {
  padding: 8rpx 6rpx;
  font-size: 22rpx;
  background: #fff;
  border: 1rpx solid #dce6f8;
  color: #3a4c68;
  line-height: 1.2;
  text-align: center;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.chip-main {
  min-width: 0;
}

.chip-sort {
  flex: 1;
  max-width: none;
}

.chip-toggle {
  color: #1f2c43;
  background: #f2fbf6;
  border-color: #d9f2e6;
}

.chip-district {
  display: inline-block;
  margin-right: 6rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dce6f8;
  min-height: auto;
  padding: 7rpx 12rpx;
}

.chip-action {
  flex: 1 1 calc(50% - 5rpx);
}

.chip-arrow-icon {
  margin-left: 4rpx;
  font-size: 14rpx;
  color: #7f8fa5;
}

.chip-active {
  background: #edf4ff;
  color: #ffffff;
}

.filter-top .chip-active,
.quick-actions .chip-active,
.chip-district.chip-active {
  background: #2f7cf6;
  color: #fff;
  border-color: #2f7cf6;
}

.advanced-panel {
  margin-top: 6rpx;
}

.filter-actions {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
}

.advanced-panel .input {
  height: 56rpx;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  margin-top: 6rpx;
}

.advanced-panel .input:first-child {
  margin-top: 0;
}

.filter-actions .btn {
  min-height: 54rpx;
  line-height: 54rpx;
  padding: 0 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.subject-panel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 30;
  background: rgba(15, 30, 58, 0.32);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 160rpx;
}

.subject-panel {
  width: 92%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 28rpx 72rpx rgba(30, 70, 140, 0.24);
}

.subject-panel-head {
  height: 84rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #edf2fb;
}

.subject-panel-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e3558;
}

.subject-panel-sub {
  padding: 14rpx 26rpx;
  font-size: 22rpx;
  color: #7386a3;
  border-bottom: 1rpx solid #f0f4fb;
  background: #f8fbff;
}

.subject-panel-reset {
  font-size: 24rpx;
  color: #2f67c8;
}

.subject-panel-body {
  display: flex;
  height: 520rpx;
}

.category-col {
  width: 210rpx;
  background: #f6f8fd;
}

.subject-col {
  flex: 1;
  background: #fff;
  padding: 18rpx 18rpx 10rpx;
}

.category-item {
  padding: 24rpx 14rpx;
  text-align: center;
  font-size: 24rpx;
  color: #4f6078;
  border-left: 6rpx solid transparent;
  transition: all 0.2s ease;
}

.category-item.active {
  background: #fff;
  color: #1f4f9e;
  border-left-color: #2f67c8;
  font-weight: 700;
}

.subject-chip {
  display: inline-block;
  margin: 0 14rpx 14rpx 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dce6f8;
  color: #3a4c68;
  background: #f9fbff;
  font-size: 24rpx;
  transition: all 0.2s ease;
}

.subject-chip.active {
  border-color: #2f67c8;
  color: #1e58bc;
  background: #ebf3ff;
}

.subject-empty {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #8a99b1;
}

.retry-btn {
  margin-top: 10rpx;
}

.skeleton-card .line {
  margin-top: 16rpx;
}

.skeleton-card .short {
  width: 72%;
}

.teacher-card-inner {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.teacher-card {
  padding: 30rpx 24rpx;
}

.teacher-avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 12rpx;
  background: #eef4fb;
  flex: 0 0 auto;
  overflow: hidden;
  display: block;
}

.teacher-avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6e86a5;
  font-size: 22rpx;
  border: 1rpx dashed #d0ddf4;
  background: #f6faff;
}

.teacher-main {
  flex: 1;
  min-width: 0;
}

.teacher-row1 {
  display: flex;
  gap: 10rpx;
  align-items: center;
}

.teacher-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2c43;
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chip-mini {
  font-size: 22rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: #eef4fb;
  color: #395b7e;
  flex: 0 0 auto;
}

.chip-mini.chip-green {
  background: #e9f8f0;
  color: #1ea55a;
}

.teacher-row2 {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #2b3a55;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.teacher-row3 {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6e8099;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.teacher-row4 {
  margin-top: 10rpx;
  display: flex;
  gap: 12rpx;
  align-items: center;
  flex-wrap: wrap;
}

.teacher-distance {
  color: #22c36a;
  font-weight: 700;
}

.teacher-meta {
  color: #5f7798;
  font-size: 22rpx;
}

.teacher-row5 {
  margin-top: 8rpx;
  color: #60799a;
  font-size: 22rpx;
}

.teacher-cta {
  margin-top: 16rpx;
  padding: 10rpx 14rpx;
  font-size: 24rpx;
  width: 180rpx;
}
